# Firebase web config for project bot-thread (PUBLIC by Firebase design — safe in client bundles).
# Copy to .env.local for local dev; set the same values in Vercel project env for production.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=bot-thread.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=bot-thread
VITE_FIREBASE_STORAGE_BUCKET=bot-thread.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
